# Star Ranker Environment Variables

# === Neon Postgres (required for server) ===
DATABASE_URL=postgresql://username:password@your-neon-host.neon.tech/neondb?sslmode=require

# === Firebase Auth (required for frontend) ===
VITE_FIREBASE_API_KEY=your_api_key
VITE_FIREBASE_AUTH_DOMAIN=star-ranker.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=star-ranker
VITE_FIREBASE_STORAGE_BUCKET=star-ranker.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=G-your_id

# === API URL (frontend ) -> backend) ===
VITE_API_URL=http://localhost:3001

# === Server Config ===
PORT=3001
# Single origin (legacy) or use CORS_ORIGINS for multiple comma-separated URLs
CORS_ORIGIN=http://localhost:5173
CORS_ORIGINS=

# Firebase Admin on Render — paste full service account JSON as one line (required for verifyIdToken)
FIREBASE_SERVICE_ACCOUNT_JSON=

# Optional: protect GET /api/seed-database?key=... (full DB seed). Omit to disable that route.
API_SEED_KEY=

# === Paystack (NGN deposits) ===
PAYSTACK_SECRET_KEY=
PAYSTACK_WEBHOOK_SECRET=
# Frontend (Vite)
VITE_PAYSTACK_PUBLIC_KEY=

# === Flutterwave (NGN deposits — optional second gateway) ===
# Secret key from Flutterwave dashboard (server only — never commit)
FLUTTERWAVE_SECRET_KEY=
# Webhook: Dashboard → Webhooks → secret hash (verif-hash header). Optional but recommended.
FLUTTERWAVE_SECRET_HASH=
# Used for inline/card encryption only; hosted checkout works without it.
FLUTTERWAVE_ENCRYPTION_KEY=
# Public key (safe in frontend)
VITE_FLUTTERWAVE_PUBLIC_KEY=

# === Frontend API override (optional; defaults to Render URL on Vercel) ===
# Must be the URL of a RUNNING Render web service (test: GET /api/health → 200 JSON).
# Wrong or dead URLs look like "CORS" errors in the browser (no Access-Control-Allow-Origin).
# VITE_API_URL=https://star-ranker.onrender.com
